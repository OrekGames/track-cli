---
import Landing from "../layouts/Landing.astro";
import Hero from "../components/Hero.astro";
import Terminal from "../components/Terminal.astro";
import KnowledgeDocs from "../components/KnowledgeDocs.astro";
import AgentWorkflows from "../components/AgentWorkflows.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import Backends from "../components/Backends.astro";

const base = import.meta.env.BASE_URL;
const repo = "https://github.com/OrekGames/track-cli";
---

<Landing>
  <header class="site-nav">
    <div class="site-nav-inner">
      <a class="brand" href={base}>
        <img
          class="brand-mark"
          src={`${base}orek-logo.png`}
          alt="OrekGames"
          width="106"
          height="150"
        />
        <span class="brand-name" translate="no">track</span>
      </a>
      <nav class="nav-links">
        <a href={`${base}overview/`}>Docs</a>
        <a href="#features">Features</a>
        <a href={`${base}installation/`}>Install</a>
        <a href={repo}>GitHub</a>
      </nav>
    </div>
  </header>

  <main>
    <Hero />
    <Terminal />
    <KnowledgeDocs />
    <AgentWorkflows />
    <FeatureGrid />
    <Backends />
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <span class="footer-brand">
        <img src={`${base}orek-logo.png`} alt="" width="25" height="36" />
        track CLI by OrekGames — released under the MIT License.
      </span>
      <nav class="footer-links">
        <a href={`${base}overview/`}>Documentation</a>
        <a href={repo}>GitHub</a>
        <a href={`${repo}/releases`}>Releases</a>
        <a href={`${repo}/blob/main/LICENSE`}>License</a>
      </nav>
    </div>
  </footer>
</Landing>
