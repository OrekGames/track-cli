---
import Landing from "../layouts/Landing.astro";
import Hero from "../components/Hero.astro";
import Terminal from "../components/Terminal.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import Backends from "../components/Backends.astro";

const base = import.meta.env.BASE_URL;
const repo = "https://github.com/OrekGames/track-cli";
---

<Landing>
  <header class="site-nav">
    <div class="container" style="display:flex;align-items:center;justify-content:space-between;padding:0;">
      <a class="brand" href={base}>
        <svg
          class="brand-mark"
          viewBox="0 0 32 32"
          width="28"
          height="28"
          aria-hidden="true"
        >
          <rect
            x="1"
            y="4"
            width="30"
            height="24"
            rx="4"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          />
          <path
            d="M8 12l4 4-4 4"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <line
            x1="15"
            y1="20"
            x2="23"
            y2="20"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
          />
        </svg>
        track
      </a>
      <nav class="nav-links">
        <a href={`${base}overview/`}>Docs</a>
        <a href="#features">Features</a>
        <a href={`${base}installation/`}>Install</a>
        <a href={repo}>GitHub</a>
      </nav>
    </div>
  </header>

  <main>
    <Hero />
    <Terminal />
    <FeatureGrid />
    <Backends />
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <span>track CLI — released under the MIT License.</span>
      <nav class="footer-links">
        <a href={`${base}overview/`}>Documentation</a>
        <a href={repo}>GitHub</a>
        <a href={`${repo}/releases`}>Releases</a>
        <a href={`${repo}/blob/main/LICENSE`}>License</a>
      </nav>
    </div>
  </footer>
</Landing>
